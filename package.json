{
  "name": "use-stick-to-bottom",
  "author": "Sam Denty <samddenty@gmail.com> (http://samdenty.com/)",
  "description": "A lightweight library for React and Vue 3 intended for AI chat applications, providing smooth scroll-to-bottom functionality with spring animations",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "dev:react": "vite --config vite.config.react.ts",
    "dev:vue": "vite --config vite.config.vue.ts",
    "build": "rm -rf dist > /dev/null 2>&1; tsc -b",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src demo --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src demo --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackblitz/use-stick-to-bottom.git"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@eslint/js": "^9.34.0",
    "@iconify-json/ph": "^1.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^15.15.0",
    "lorem-ipsum": "^2.0.8",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.15",
    "vite-plugin-dts": "^4.5.3",
    "vue": "^3.5.20",
    "vue-eslint-parser": "^10.2.0"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
