{
  "name": "use-stick-to-bottom",
  "author": "Sam Denty <samddenty@gmail.com> (http://samdenty.com/)",
  "description": "A lightweight Vue 3 library intended for AI chat applications, providing smooth scroll-to-bottom functionality with spring animations",
  "version": "2.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    }
  },
  "typesVersions": {
    "*": {
      "vue": [
        "./dist/vue.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src demo --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src demo --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackblitz/use-stick-to-bottom.git"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@eslint/js": "^9.34.0",
    "@iconify-json/ph": "^1.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^15.15.0",
    "lorem-ipsum": "^2.0.8",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.15",
    "vite-plugin-dts": "^4.5.3",
    "vue": "^3.5.20",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.6"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
